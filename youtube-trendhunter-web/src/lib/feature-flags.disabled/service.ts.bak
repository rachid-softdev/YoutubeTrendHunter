// ============================================
// FeatureGateService - Central Service
// ============================================

import type { 
  IEntitlementRepository, 
  ICacheService,
  FeatureValue,
  ConsumeResult,
  EntitlementMap,
  DebugTrace,
  ResolveSource,
  DowngradeImpact,
  DowngradePreview,
  ExperimentConfig
} from "./types"
import { 
  FeatureNotAvailableError, 
  LimitReachedError, 
  SubscriptionExpiredError 
} from "./types"
import type { FeatureType, DowngradeStrategy } from "@prisma/client"

// Simple murmurhash for A/B testing
function murmurhash(key: string): number {
  let h = 0
  for (let i = 0; i < key.length; i++) {
    const char = key.charCodeAt(i)
    h = Math.imul(h ^ char, 0x5bd1e995)
    h ^= h >>> 15
  }
  return (h >>> 0) % 100
}

export class FeatureGateService {
  private repository: IEntitlementRepository
  private cache: ICacheService
  private cacheVersion = 1

  constructor(repository: IEntitlementRepository, cache: ICacheService) {
    this.repository = repository
    this.cache = cache
  }

  // ============================================
  // Core Methods
  // ============================================

  /**
   * Check if a feature is enabled for an organization
   */
  async hasFeature(orgId: string, featureKey: string): Promise<boolean> {
    const resolved = await this.resolveFeature(orgId, featureKey)
    if (resolved.featureType === "LIMIT") {
      return resolved.limitValue !== null && resolved.limitValue > 0
    }
    return resolved.value as boolean
  }

  /**
   * Get the numeric limit for a feature (null = unlimited)
   */
  async getLimit(orgId: string, limitKey: string): Promise<number | null> {
    const resolved = await this.resolveFeature(orgId, limitKey)
    if (resolved.featureType !== "LIMIT") {
      return null
    }
    return resolved.limitValue
  }

  /**
   * Assert that a feature is available, throw if not
   */
  async assertFeature(orgId: string, featureKey: string): Promise<void> {
    const hasIt = await this.hasFeature(orgId, featureKey)
    if (!hasIt) {
      const resolved = await this.resolveFeature(orgId, featureKey)
      throw new FeatureNotAvailableError(
        featureKey,
        this.getRequiredPlan(resolved),
        resolved.planKey || "free"
      )
    }
  }

  /**
   * Check if can consume n units (default 1)
   */
  async canConsume(orgId: string, featureKey: string, n: number = 1): Promise<boolean> {
    const limitValue = await this.getLimit(orgId, featureKey)
    
    // Unlimited
    if (limitValue === null) return true
    
    // Get current usage
    const usage = await this.repository.getCurrentUsage(orgId, featureKey)
    const currentUsage = usage?.usageCount ?? 0
    
    return (currentUsage + n) <= limitValue
  }

  /**
   * Consume n units (default 1), returns result
   */
  async consume(orgId: string, featureKey: string, n: number = 1): Promise<ConsumeResult> {
    // Get feature definition to check type
    const feature = await this.repository.getFeature(featureKey)
    if (!feature) {
      return {
        success: false,
        feature: featureKey,
        used: 0,
        limit: null,
        remaining: null,
        error: "FEATURE_NOT_AVAILABLE"
      }
    }

    // For boolean features, just check enabled
    if (feature.type === "BOOLEAN") {
      const hasIt = await this.hasFeature(orgId, featureKey)
      return {
        success: hasIt,
        feature: featureKey,
        used: 0,
        limit: null,
        remaining: null
      }
    }

    // For limit features
    if (feature.type === "LIMIT") {
      const limitValue = await this.getLimit(orgId, featureKey)
      
      // Unlimited
      if (limitValue === null) {
        await this.repository.consumeUsage(orgId, featureKey, n)
        return {
          success: true,
          feature: featureKey,
          used: n,
          limit: null,
          remaining: null
        }
      }

      // Check limit
      const canUse = await this.canConsume(orgId, featureKey, n)
      if (!canUse) {
        const usage = await this.repository.getCurrentUsage(orgId, featureKey)
        const currentUsage = usage?.usageCount ?? 0
        const resetAt = usage?.periodEnd ?? this.getNextPeriodEnd()
        
        return {
          success: false,
          feature: featureKey,
          used: currentUsage,
          limit: limitValue,
          remaining: 0,
          resetAt,
          error: "LIMIT_REACHED",
          limitReached: {
            feature: featureKey,
            limit: limitValue,
            used: currentUsage,
            resetAt,
            upgradeUrl: "/billing/upgrade"
          }
        }
      }

      // Consume
      const updated = await this.repository.consumeUsage(orgId, featureKey, n)
      const newUsage = updated?.usageCount ?? n
      
      return {
        success: true,
        feature: featureKey,
        used: newUsage,
        limit: limitValue,
        remaining: limitValue - newUsage,
        resetAt: updated?.periodEnd ?? this.getNextPeriodEnd()
      }
    }

    // For experiments, just return success
    return {
      success: true,
      feature: featureKey,
      used: 0,
      limit: null,
      remaining: null
    }
  }

  /**
   * Get all entitlements for an org
   */
  async getAllEntitlements(orgId: string): Promise<EntitlementMap> {
    // Get subscription
    const subscription = await this.repository.getActiveSubscription(orgId)
    const planKey = subscription?.planKey ?? "free"
    
    // Get plan
    const plan = await this.repository.getPlan(planKey)
    const planName = plan?.name ?? "Free"

    // Get all active features
    const features = await this.repository.getActiveFeatures()
    
    const featuresMap: Record<string, boolean> = {}
    const limitsMap: Record<string, number | null> = {}
    const usageMap: Record<string, number> = {}
    const resetAtMap: Record<string, Date | null> = {}
    const experimentBuckets: Record<string, boolean> = {}

    for (const feature of features) {
      const resolved = await this.resolveFeature(orgId, feature.key)
      
      if (feature.type === "BOOLEAN") {
        featuresMap[feature.key] = resolved.value as boolean
      } else if (feature.type === "LIMIT") {
        featuresMap[feature.key] = resolved.limitValue !== null && resolved.limitValue > 0
        limitsMap[feature.key] = resolved.limitValue
        
        const usage = await this.repository.getCurrentUsage(orgId, feature.key)
        usageMap[feature.key] = usage?.usageCount ?? 0
        resetAtMap[feature.key] = usage?.periodEnd ?? null
      } else if (feature.type === "EXPERIMENT") {
        experimentBuckets[feature.key] = resolved.value as boolean
      }
    }

    return {
      plan: planName,
      planKey,
      features: featuresMap,
      limits: limitsMap,
      usage: usageMap,
      resetAt: resetAtMap,
      experimentBuckets
    }
  }

  /**
   * Get debug trace for a feature
   */
  async getDebugTrace(orgId: string, featureKey: string): Promise<DebugTrace> {
    const resolved = await this.resolveFeature(orgId, featureKey)
    const feature = await this.repository.getFeature(featureKey)

    return {
      feature: featureKey,
      resolvedVia: resolved.source,
      value: resolved.value,
      overrideId: resolved.overrideId,
      expiresAt: resolved.expiresAt,
      planKey: resolved.planKey,
      planName: resolved.planName,
      limitValue: resolved.limitValue,
      configJson: resolved.configJson,
      isExperiment: feature?.type === "EXPERIMENT",
      experimentConfig: feature?.type === "EXPERIMENT" 
        ? (feature.defaultConfig as ExperimentConfig | null) 
        : undefined
    }
  }

  /**
   * Invalidate cache for an org
   */
  async invalidateCache(orgId: string): Promise<void> {
    await this.cache.invalidateEntitlements(orgId)
  }

  // ============================================
  // A/B Testing Methods
  // ============================================

  /**
   * Check if a user is in an experiment
   * @param userId - User identifier for stable hashing
   */
  isInExperiment(userId: string, experimentKey: string): boolean {
    const feature = this.repository.getFeature(experimentKey) // Sync for now
    if (!feature) return false

    const config = feature.defaultConfig as ExperimentConfig | null
    if (!config) return false

    // Stable hash based on seed + userId
    const bucket = murmurhash(`${config.seed}:${userId}`)
    return bucket < config.percentage
  }

  getExperimentConfig(experimentKey: string): ExperimentConfig | null {
    const feature = this.repository.getFeature(experimentKey)
    if (!feature) return null
    return feature.defaultConfig as ExperimentConfig | null
  }

  // ============================================
  // Internal Resolution Methods
  // ============================================

  private async resolveFeature(orgId: string, featureKey: string): Promise<ResolvedFeature> {
    // 1. Check user override (not implemented in this basic version)
    // For now, we'll check org override first

    // 2. Check org override
    const orgOverride = await this.repository.getOverride("ORG", orgId, featureKey)
    if (orgOverride) {
      return {
        source: "org_override",
        value: orgOverride.enabled,
        overrideId: orgOverride.id,
        expiresAt: orgOverride.expiresAt ?? undefined,
        limitValue: orgOverride.limitValue ?? undefined,
        configJson: orgOverride.configJson as Record<string, unknown> | undefined,
        featureType: "BOOLEAN"
      }
    }

    // 3. Check subscription/plan
    const subscription = await this.repository.getActiveSubscription(orgId)
    
    // Check if subscription is valid
    if (subscription) {
      // Check for expired subscription
      if (subscription.currentPeriodEnd && subscription.currentPeriodEnd < new Date()) {
        if (subscription.status !== "TRIALING" || !subscription.trialEnd || subscription.trialEnd < new Date()) {
          // Subscription expired, fall through to fallback
        } else {
          // Valid trial
        }
      }
    }

    const planKey = subscription?.planKey ?? "free"
    const plan = await this.repository.getPlan(planKey)
    const planName = plan?.name ?? "Free"

    // Get feature type
    const feature = await this.repository.getFeature(featureKey)
    const featureType = feature?.type ?? "BOOLEAN"

    if (!plan) {
      // Fallback - no plan
      return {
        source: "fallback",
        value: false,
        planKey: "free",
        planName: "Free",
        featureType
      }
    }

    // Get plan feature config
    const planFeature = await this.repository.getPlanFeature(plan.id, featureKey)
    if (!planFeature) {
      // Feature not in plan
      return {
        source: "plan",
        value: false,
        planKey,
        planName,
        featureType
      }
    }

    return {
      source: "plan",
      value: planFeature.enabled,
      planKey,
      planName,
      limitValue: planFeature.limitValue ?? undefined,
      configJson: planFeature.configJson as Record<string, unknown> | undefined,
      featureType
    }
  }

  private getRequiredPlan(resolved: ResolvedFeature): string {
    // Simple heuristic - if feature is enabled, no specific plan required
    if (resolved.value === true || resolved.limitValue !== null) {
      return "free"
    }
    return resolved.planKey ?? "pro"
  }

  private getNextPeriodEnd(): Date {
    const now = new Date()
    return new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59)
  }

  // ============================================
  // Downgrade Preview
  // ============================================

  async getDowngradePreview(orgId: string, targetPlanKey: string): Promise<DowngradeImpact> {
    const currentSub = await this.repository.getActiveSubscription(orgId)
    const currentPlanKey = currentSub?.planKey ?? "free"
    
    const currentPlan = await this.repository.getPlan(currentPlanKey)
    const targetPlan = await this.repository.getPlan(targetPlanKey)
    
    if (!currentPlan || !targetPlan) {
      return {
        willLoseFeatures: [],
        willKeepFeatures: [],
        currentPeriodEnd: currentSub?.currentPeriodEnd ?? null,
        effectiveDate: null
      }
    }

    const currentFeatures = await this.repository.getPlanFeatures(currentPlan.id)
    const targetFeatures = await this.repository.getPlanFeatures(targetPlan.id)
    
    const targetFeatureMap = new Map(targetFeatures.map(f => [f.feature.key, f]))
    
    const willLoseFeatures: DowngradePreview[] = []
    const willKeepFeatures: DowngradePreview[] = []

    for (const current of currentFeatures) {
      const target = targetFeatureMap.get(current.feature.key)
      
      if (!target || !target.enabled) {
        // Will lose access
        willLoseFeatures.push({
          featureKey: current.feature.key,
          featureName: current.feature.name,
          currentValue: current.enabled,
          newValue: target?.enabled ?? false,
          strategy: target?.downgradeStrategy ?? "GRACEFUL",
          willLoseAccess: true,
          currentPeriodEnd: currentSub?.currentPeriodEnd ?? undefined
        })
      } else {
        // Keep access
        willKeepFeatures.push({
          featureKey: current.feature.key,
          featureName: current.feature.name,
          currentValue: current.enabled,
          newValue: target.enabled,
          strategy: target.downgradeStrategy,
          willLoseAccess: false
        })
      }
    }

    // Calculate effective date based on strategy
    let effectiveDate: Date | null = null
    const hasGraceful = willLoseFeatures.some(f => f.strategy === "GRACEFUL")
    
    if (hasGraceful && currentSub?.currentPeriodEnd) {
      effectiveDate = currentSub.currentPeriodEnd
    }

    return {
      willLoseFeatures,
      willKeepFeatures,
      currentPeriodEnd: currentSub?.currentPeriodEnd ?? null,
      effectiveDate
    }
  }
}

interface ResolvedFeature {
  source: ResolveSource
  value: FeatureValue
  overrideId?: string
  expiresAt?: Date
  planKey?: string
  planName?: string
  limitValue?: number | null
  configJson?: Record<string, unknown>
  featureType: FeatureType
}

// Export factory function for dependency injection
export function createFeatureGateService(
  repository: IEntitlementRepository,
  cache: ICacheService
): FeatureGateService {
  return new FeatureGateService(repository, cache)
}

// Export default instance
import { entitlementRepository } from "./repository"
import { cacheService } from "./cache"

export const featureGateService = createFeatureGateService(entitlementRepository, cacheService)