{
  "name": "@youtube-trendhunter/root",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "prepare": "husky",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=youtube-trendhunter-web",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=youtube-trendhunter-web",
    "start": "turbo run start --filter=youtube-trendhunter-web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --filter=youtube-trendhunter-web",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "setup:stripe": "npx tsx scripts/setup-stripe.ts",
    "stripe:setup": "node scripts/setup-stripe-cli.js",
    "stripe:stop": "node scripts/stop-stripe-cli.js",
    "stripe:test": "node scripts/stripe-test-webhooks.js",
    "dev:services": "node scripts/setup-mailhog.js",
    "dev:services:stop": "node scripts/stop-mailhog.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "turbo": "^2.4.4"
  },
  "lint-staged": {
    "*": [
      "biome format --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "pnpm run typecheck"
    ]
  }
}
