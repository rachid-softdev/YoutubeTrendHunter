# Environment variables template for YoutubeTrendHunter Extension
# Copy this to .env for development

# API Configuration (for extension to communicate with backend)
VITE_API_BASE_URL="http://localhost:3000"

# YouTube API
YOUTUBE_API_KEY="xxx"

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS="true"
NEXT_PUBLIC_EXTENSION_VERSION="1.0.0"

# Extension specific
EXTENSION_MODE="true"