# Environment variables template for YoutubeTrendHunter Mobile
# Copy this to .env for development

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:3000"
API_BASE_URL="http://localhost:3000/api"

# Authentication
NEXT_PUBLIC_AUTH_GOOGLE_CLIENT_ID="your-google-client-id"
NEXT_PUBLIC_AUTH_GOOGLE_CLIENT_SECRET="your-google-client-secret"

# YouTube API
YOUTUBE_API_KEY="xxx"

# Analytics
NEXT_PUBLIC_POSTHOG_KEY="phc_xxx"
NEXT_PUBLIC_POSTHOG_URL="https://app.posthog.com"

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS="true"
NEXT_PUBLIC_APP_VERSION="1.0.0"